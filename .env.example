# Discord webhook delivery
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_USERNAME=AI News Bot
DISCORD_WEBHOOK_AVATAR_URL=

# OpenAI API Key / compatible endpoint
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=glm-5.1
OPENAI_BASE_URL=
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_PROVIDER=auto
AI_MAX_INPUT_ITEMS=8
SEMANTIC_DEDUPE_ENABLED=true
SEMANTIC_SIMILARITY_THRESHOLD=0.85
SEMANTIC_MEMORY_MAX_AGE_HOURS=168
SEMANTIC_EMBEDDING_BATCH_SIZE=20
SEMANTIC_EMBEDDING_MAX_CHARS=2000

# Enable one or more sources: x,hackernews,reddit,rss
ENABLED_SOURCES=x,hackernews,reddit,rss

# X auth cookies from a logged-in browser session
X_AUTH_TOKEN=your_x_auth_token_here
X_CT0=your_x_ct0_here
X_MAX_RESULTS=20

# Hacker News
HACKERNEWS_KEYWORDS=AI,LLM,OpenAI,Anthropic,Claude,Gemini,agents
HACKERNEWS_MAX_RESULTS=12

# Reddit
REDDIT_SUBREDDITS=MachineLearning,LocalLLaMA
REDDIT_SEARCH_QUERY=AI OR LLM OR OpenAI OR Anthropic OR Claude OR Gemini
REDDIT_MAX_RESULTS=10

# RSS
RSS_FEEDS=https://openai.com/news/rss.xml,https://huggingface.co/blog/feed.xml
RSS_MAX_RESULTS_PER_FEED=25

# General filtering
HOURS_LOOKBACK=6
MIN_IMPORTANCE=6
MAX_POSTS_PER_RUN=10

# Optional account tuning
PRIORITY_ACCOUNTS=
BLOCKED_ACCOUNTS=

# Cron schedule
SCHEDULE_CRON=0 */3 * * *
TIMEZONE=Asia/Ho_Chi_Minh

# Request timeout for source/OpenAI calls
REQUEST_TIMEOUT_MS=30000
HTTP_USER_AGENT=ai-news-bot/1.0 (+https://github.com/)

# Set true to skip Discord login/posting and print the digest instead
DRY_RUN=false
RUN_ONCE=false

# Log verbosity: error, warn, info, debug
LOG_LEVEL=info

# Optional override for the state file path
STATE_FILE=

# AI filter prompt
FILTER_PROMPT=Select the most important and impactful AI/tech news. Focus on: new model releases, major company announcements, breakthroughs, research papers, and significant industry changes.
