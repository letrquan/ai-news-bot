# Discord Token (selfbot - your user token)
DISCORD_TOKEN=your_discord_user_token_here

# Channel ID to send updates to
DISCORD_CHANNEL_ID=your_channel_id_here

# X auth cookies from a logged-in browser session
X_AUTH_TOKEN=your_x_auth_token_here
X_CT0=your_x_ct0_here

# OpenAI API Key / compatible endpoint
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Max timeline tweets to crawl per run
TWITTER_MAX_RESULTS=20

# How many hours back to look
HOURS_LOOKBACK=3

# Minimum AI score to keep (1-10)
MIN_IMPORTANCE=6

# Maximum posts sent to Discord for each run
MAX_POSTS_PER_RUN=10

# Optional account tuning
PRIORITY_ACCOUNTS=
BLOCKED_ACCOUNTS=

# Cron schedule
SCHEDULE_CRON=0 */3 * * *
TIMEZONE=Asia/Ho_Chi_Minh

# Request timeout for X/OpenAI calls
REQUEST_TIMEOUT_MS=30000

# Set true to skip Discord login/posting and print the digest instead
DRY_RUN=false

# Log verbosity: error, warn, info, debug
LOG_LEVEL=info

# Optional override for the state file path
STATE_FILE=

# AI filter prompt
FILTER_PROMPT=Select the most important and impactful AI/tech news. Focus on: new model releases, major company announcements, breakthroughs, and significant industry changes.
