# Discord Token (selfbot - YOUR user token)
DISCORD_TOKEN=your_discord_user_token_here

# Channel ID to send updates to
DISCORD_CHANNEL_ID=your_channel_id_here

# Apify API Token (https://console.apify.com/settings/integrations)
APIFY_TOKEN=your_apify_token_here

# Apify Twitter Scraper Actor ID (default is the official Twitter Scraper)
APIFY_ACTOR_ID=61RPP7dywgiy0JPD0

# OpenAI API Key
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Search terms (comma-separated)
TWITTER_SEARCH_TERMS=AI,artificial intelligence,LLM,GPT,OpenAI,Claude,Gemini,Machine Learning

# Max tweets to crawl per run
TWITTER_MAX_RESULTS=20

# How many hours back to look
HOURS_LOOKBACK=3

# Cron schedule (default: every 3 hours)
SCHEDULE_CRON=0 */3 * * *

# AI filter prompt - what kind of news to look for
FILTER_PROMPT=Select the most important and impactful AI/tech news. Focus on: new model releases, major company announcements, breakthroughs, and significant industry changes.
